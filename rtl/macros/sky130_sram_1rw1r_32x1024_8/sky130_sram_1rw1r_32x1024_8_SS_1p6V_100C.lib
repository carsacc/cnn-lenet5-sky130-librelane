        min_capacitance : 0.0017224999999999999;  
        memory_read(){ 
            address : addr0; 
        }
        pin(dout0[31:0]){
        timing(){ 
            timing_sense : non_unate; 
            related_pin : "clk0"; 
            timing_type : falling_edge; 
            cell_rise(CELL_TABLE) {
            values("6.446, 6.912, 7.688",\
                   "6.446, 6.912, 7.688",\
                   "6.453, 6.919, 7.695");
            }
            cell_fall(CELL_TABLE) {
            values("6.446, 6.912, 7.688",\
                   "6.446, 6.912, 7.688",\
                   "6.453, 6.919, 7.695");
            }
            rise_transition(CELL_TABLE) {
            values("0.2, 0.481, 1.715",\
                   "0.2, 0.481, 1.715",\
                   "0.2, 0.481, 1.715");
            }
            fall_transition(CELL_TABLE) {
            values("0.2, 0.481, 1.715",\
                   "0.2, 0.481, 1.715",\
                   "0.2, 0.481, 1.715");
            }
        }
        }
    }

    bus(addr0){
