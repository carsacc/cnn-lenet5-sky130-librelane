            }
        }
    }

    pin(clk0){
        clock             : true;
        direction  : input; 
        capacitance : 0.006889999999999999;  
        internal_power(){
            when : "!csb0 & !web0"; 
            rise_power(scalar){
                values("7.202656e-01");
            }
            fall_power(scalar){
                values("1.004399e+00");
            }
        }
        internal_power(){
            when : "csb0 & !web0"; 
            rise_power(scalar){
                values("4.615884e-01");
            }
            fall_power(scalar){
                values("3.798705e-01");
            }
        }
        internal_power(){
            when : "!csb0 & web0"; 
