            values("-0.032, -0.032, -0.032",\
                   "-0.032, -0.032, -0.032",\
                   "-0.032, -0.032, -0.032");
            }
        }
        }
    }
    bus(dout0){
        bus_type  : data; 
        direction  : output; 
        max_capacitance : 0.027559999999999998;  
        min_capacitance : 0.0017224999999999999;  
        memory_read(){ 
            address : addr0; 
        }
        pin(dout0[31:0]){
        timing(){ 
            timing_sense : non_unate; 
            related_pin : "clk0"; 
            timing_type : falling_edge; 
            cell_rise(CELL_TABLE) {
            values("4.299, 4.342, 4.427",\
                   "4.299, 4.343, 4.427",\
                   "4.307, 4.35, 4.435");
            }
            cell_fall(CELL_TABLE) {
            values("4.299, 4.342, 4.427",\
                   "4.299, 4.343, 4.427",\
                   "4.307, 4.35, 4.435");
            }
            rise_transition(CELL_TABLE) {
            values("0.05, 0.101, 0.313",\
                   "0.05, 0.101, 0.313",\
                   "0.051, 0.101, 0.313");
            }
            fall_transition(CELL_TABLE) {
            values("0.05, 0.101, 0.313",\
                   "0.05, 0.101, 0.313",\
                   "0.051, 0.101, 0.313");
            }
        }
        }
    }

    bus(addr0){
        bus_type  : addr; 
        direction  : input; 
