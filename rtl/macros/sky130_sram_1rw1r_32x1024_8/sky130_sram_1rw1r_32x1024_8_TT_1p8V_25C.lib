            }
        }
    }

    pin(clk0){
        clock             : true;
        direction  : input; 
        capacitance : 0.006889999999999999;  
        internal_power(){
            when : "!csb0 & !web0"; 
            rise_power(scalar){
                values("1.780904e+00");
            }
            fall_power(scalar){
                values("2.201942e+00");
            }
        }
        internal_power(){
            when : "csb0 & !web0"; 
            rise_power(scalar){
                values("1.134338e+00");
            }
            fall_power(scalar){
                values("9.137561e-01");
            }
        }
        internal_power(){
            when : "!csb0 & web0"; 
            rise_power(scalar){
                values("2.288202e+00");
            }
            fall_power(scalar){
                values("2.081648e+00");
            }
        }
        internal_power(){
            when : "csb0 & web0"; 
            rise_power(scalar){
                values("9.239672e-01");
            }
            fall_power(scalar){
                values("9.348258e-01");
            }
        }
        timing(){ 
            timing_type : "min_pulse_width"; 
